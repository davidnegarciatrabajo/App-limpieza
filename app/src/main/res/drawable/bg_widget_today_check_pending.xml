<?xml version="1.0" encoding="utf-8"?>
<selector xmlns:android="http://schemas.android.com/apk/res/android">
    <item android:state_pressed="true">
        <shape android:shape="oval">
            <solid android:color="#E2D2A9" />
            <stroke
                android:width="1dp"
                android:color="#9F7A48" />
        </shape>
    </item>
    <item>
        <shape android:shape="oval">
            <solid android:color="#F8F1DE" />
            <stroke
                android:width="1dp"
                android:color="#B59361" />
        </shape>
    </item>
</selector>

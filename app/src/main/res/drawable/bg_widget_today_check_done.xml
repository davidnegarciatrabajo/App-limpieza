<?xml version="1.0" encoding="utf-8"?>
<selector xmlns:android="http://schemas.android.com/apk/res/android">
    <item android:state_pressed="true">
        <shape android:shape="oval">
            <solid android:color="#8CCAA4" />
            <stroke
                android:width="1dp"
                android:color="#2C7E4B" />
        </shape>
    </item>
    <item>
        <shape android:shape="oval">
            <solid android:color="#CFEAD9" />
            <stroke
                android:width="1dp"
                android:color="#3B8B57" />
        </shape>
    </item>
</selector>
